---
/**
 * QentriQ Blog Page
 */
import Header from '../../components/Header.astro';
import '../../styles/tokens.css';
import '../../styles/landing.css';
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="QentriQ Blog - News and updates about post-quantum cryptography and PKI." />
  <title>Blog - QentriQ</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    .blog-content {
      max-width: 800px;
      margin: 0 auto;
      padding: var(--q-space-16, 4rem) var(--q-space-8, 2rem);
      text-align: center;
    }

    .blog-content h2 {
      font-size: 1.5rem;
      margin-bottom: var(--q-space-4, 1rem);
      color: var(--q-gray-8, #f4f4f5);
    }

    :root[data-theme='light'] .blog-content h2 {
      color: var(--q-gray-1, #020202);
    }

    .blog-content p {
      color: var(--q-gray-6, #98989f);
      margin-bottom: var(--q-space-8, 2rem);
    }

    :root[data-theme='light'] .blog-content p {
      color: var(--q-gray-5, #64646c);
    }

    .coming-soon {
      display: inline-block;
      padding: var(--q-space-2, 0.5rem) var(--q-space-4, 1rem);
      background: rgba(52, 71, 255, 0.2);
      border: 1px solid var(--sl-color-accent, #3447ff);
      border-radius: var(--q-radius-md, 0.5rem);
      color: var(--sl-color-accent-high, #60a5fa);
      font-size: 0.875rem;
      font-weight: 500;
    }

    :root[data-theme='light'] .coming-soon {
      background: rgba(0, 101, 218, 0.1);
      border-color: var(--sl-color-accent, #0065da);
      color: var(--sl-color-accent, #0065da);
    }
  </style>
</head>

<body class="landing-page">
  <Header />

  <!-- Hero -->
  <section class="landing-hero">
    <h1 class="animate-in">Blog</h1>
    <p class="animate-in" style="animation-delay: 0.1s">
      News, tutorials, and updates about post-quantum cryptography.
    </p>
  </section>

  <div class="blog-content">
    <h2>Coming Soon</h2>
    <p>
      We're working on articles about post-quantum cryptography, PKI best practices,
      and migration strategies. Check back soon!
    </p>
    <span class="coming-soon">Blog launching soon</span>
  </div>

  <!-- Footer -->
  <footer class="landing-footer">
    <p>
      Open source under Apache 2.0 license.
      <a href="https://github.com/remiblancher/post-quantum-pki">Contribute on GitHub</a>
    </p>
  </footer>
</body>
</html>
