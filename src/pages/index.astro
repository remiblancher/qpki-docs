---
import { Image } from 'astro:assets';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="QentriQ - Quantum-Safe PKI in Go. Build and deploy post-quantum X.509 infrastructure with ML-DSA, ML-KEM, and hybrid certificates." />
  <title>QentriQ - Quantum-Safe PKI in Go</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --accent: #4f46e5;
      --accent-light: #818cf8;
      --bg-dark: #0f172a;
      --bg-darker: #020617;
      --text: #f8fafc;
      --text-muted: #94a3b8;
    }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: var(--bg-dark);
      color: var(--text);
      line-height: 1.6;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    /* Navigation */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .nav-logo {
      font-size: 1.5rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .nav-logo svg {
      width: 32px;
      height: 32px;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }

    .nav-links a {
      color: var(--text-muted);
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: var(--text);
    }

    .nav-github {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255, 255, 255, 0.1);
      padding: 0.5rem 1rem;
      border-radius: 0.5rem;
    }

    /* Hero */
    .hero {
      text-align: center;
      padding: 6rem 2rem;
      background: linear-gradient(180deg, var(--bg-dark) 0%, var(--bg-darker) 100%);
    }

    .hero h1 {
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 800;
      margin-bottom: 1.5rem;
      background: linear-gradient(135deg, var(--text) 0%, var(--accent-light) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      font-size: 1.25rem;
      color: var(--text-muted);
      max-width: 600px;
      margin: 0 auto 2.5rem;
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      padding: 0.875rem 1.75rem;
      border-radius: 0.5rem;
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.2s;
    }

    .btn-primary {
      background: var(--accent);
      color: white;
    }

    .btn-primary:hover {
      background: var(--accent-light);
    }

    .btn-secondary {
      background: transparent;
      border: 2px solid var(--text-muted);
      color: var(--text);
    }

    .btn-secondary:hover {
      border-color: var(--text);
    }

    /* Features */
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      padding: 4rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .feature {
      text-align: center;
      padding: 2rem;
      background: rgba(255, 255, 255, 0.02);
      border-radius: 1rem;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .feature-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .feature h3 {
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
    }

    .feature p {
      color: var(--text-muted);
      font-size: 0.95rem;
    }

    /* Code Preview */
    .code-section {
      background: var(--bg-darker);
      padding: 4rem 2rem;
      text-align: center;
    }

    .code-section h2 {
      font-size: 1.75rem;
      margin-bottom: 2rem;
    }

    .code-block {
      display: inline-block;
      text-align: left;
      background: #1e293b;
      padding: 1.5rem 2rem;
      border-radius: 0.75rem;
      font-family: 'SF Mono', Monaco, 'Courier New', monospace;
      font-size: 0.9rem;
      overflow-x: auto;
      max-width: 100%;
    }

    .code-block .prompt {
      color: var(--accent-light);
    }

    .code-block .command {
      color: var(--text);
    }

    /* Standards */
    .standards {
      padding: 4rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
      text-align: center;
    }

    .standards h2 {
      font-size: 1.75rem;
      margin-bottom: 1rem;
    }

    .standards p {
      color: var(--text-muted);
      margin-bottom: 2rem;
    }

    .standards-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }

    .standard-badge {
      background: rgba(79, 70, 229, 0.1);
      border: 1px solid var(--accent);
      padding: 0.5rem 1rem;
      border-radius: 2rem;
      font-size: 0.9rem;
      color: var(--accent-light);
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 2rem;
      color: var(--text-muted);
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    footer a {
      color: var(--accent-light);
    }

    /* Responsive */
    @media (max-width: 768px) {
      nav {
        flex-direction: column;
        gap: 1rem;
      }

      .nav-links {
        gap: 1rem;
      }

      .hero {
        padding: 4rem 1.5rem;
      }

      .hero-buttons {
        flex-direction: column;
        align-items: center;
      }

      .btn {
        width: 100%;
        max-width: 300px;
      }
    }
  </style>
</head>

<body>
  <!-- Navigation -->
  <nav>
    <a href="/" class="nav-logo">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40">
        <circle cx="20" cy="20" r="18" fill="#4f46e5" />
        <text x="20" y="26" text-anchor="middle" fill="white" font-family="system-ui" font-weight="bold" font-size="16">Q</text>
      </svg>
      QentriQ
    </a>
    <div class="nav-links">
      <a href="/about/">About</a>
      <a href="/compare/">Compare</a>
      <a href="/pki/readme/">Docs</a>
      <a href="/lab/overview/">Lab</a>
      <a href="https://github.com/remiblancher/post-quantum-pki" class="nav-github">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <h1>Quantum-Safe PKI in Go</h1>
    <p>
      Build and deploy post-quantum X.509 infrastructure with ML-DSA, ML-KEM,
      and hybrid certificates. Standards-compliant, interoperable, CLI-first.
    </p>
    <div class="hero-buttons">
      <a href="/pki/readme/" class="btn btn-primary">Get Started</a>
      <a href="/lab/overview/" class="btn btn-secondary">Try the Lab</a>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="feature">
      <div class="feature-icon">🔐</div>
      <h3>Post-Quantum Ready</h3>
      <p>ML-DSA, ML-KEM, SLH-DSA. FIPS 203/204/205 compliant algorithms ready for the quantum era.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">🔄</div>
      <h3>Hybrid Certificates</h3>
      <p>Catalyst mode for dual-algorithm certificates. Smooth migration from classical to post-quantum.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">⚡</div>
      <h3>CLI-First</h3>
      <p>Single binary, no dependencies. Script everything. Perfect for automation and DevOps.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">🔗</div>
      <h3>Interoperable</h3>
      <p>Tested with OpenSSL, BouncyCastle, and more. Standards-compliant X.509 certificates.</p>
    </div>
  </section>

  <!-- Code Preview -->
  <section class="code-section">
    <h2>Quick Start</h2>
    <div class="code-block">
      <div><span class="prompt">$</span> <span class="command">qpki ca init --profile pqc-root-ca.yaml --var cn="My PQC Root"</span></div>
      <div><span class="prompt">$</span> <span class="command">qpki cert issue --profile pqc-server.yaml --cn "server.example.com"</span></div>
      <div><span class="prompt">$</span> <span class="command">qpki ocsp serve --port 8080</span></div>
    </div>
  </section>

  <!-- Standards -->
  <section class="standards">
    <h2>Standards Compliant</h2>
    <p>Built on NIST post-quantum cryptography standards and industry PKI specifications.</p>
    <div class="standards-grid">
      <span class="standard-badge">FIPS 203 (ML-KEM)</span>
      <span class="standard-badge">FIPS 204 (ML-DSA)</span>
      <span class="standard-badge">FIPS 205 (SLH-DSA)</span>
      <span class="standard-badge">RFC 5280 (X.509)</span>
      <span class="standard-badge">RFC 6960 (OCSP)</span>
      <span class="standard-badge">RFC 3161 (TSA)</span>
      <span class="standard-badge">RFC 5652 (CMS)</span>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <p>
      Open source under Apache 2.0 license.
      <a href="https://github.com/remiblancher/post-quantum-pki">Contribute on GitHub</a>
    </p>
  </footer>
</body>
</html>
