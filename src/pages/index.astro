---
/**
 * QentriQ Landing Page
 * Redesigned with Biome-inspired design system
 */
import FeatureCard from '../components/FeatureCard.astro';
import CardGrid from '../components/CardGrid.astro';
import StandardBadge from '../components/StandardBadge.astro';
import Header from '../components/Header.astro';
import PackageManagerCommand from '../components/PackageManagerCommand.astro';
import '../styles/tokens.css';
import '../styles/landing.css';
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="QentriQ - Quantum-Safe PKI in Go. Build and deploy post-quantum X.509 infrastructure with ML-DSA, ML-KEM, and hybrid certificates." />
  <title>QentriQ - Quantum-Safe PKI in Go</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body class="landing-page">
  <Header />

  <!-- Hero -->
  <section class="landing-hero">
    <h1 class="animate-in">Quantum-Safe PKI in Go</h1>
    <p class="animate-in" style="animation-delay: 0.1s">
      Build and deploy post-quantum X.509 infrastructure with ML-DSA, ML-KEM,
      and hybrid certificates. Standards-compliant, interoperable, CLI-first.
    </p>
    <div class="landing-buttons animate-in" style="animation-delay: 0.2s">
      <a href="/qpki/getting-started/quick-start/" class="btn btn-primary">
        Get Started
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/qlab/overview/" class="btn btn-secondary">
        Try the Lab
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="landing-section">
    <CardGrid columns={4}>
      <FeatureCard title="Post-Quantum Ready" icon="🔐">
        ML-DSA, ML-KEM, SLH-DSA. FIPS 203/204/205 compliant algorithms ready for the quantum era.
      </FeatureCard>
      <FeatureCard title="Hybrid Certificates" icon="🔄">
        Catalyst mode for dual-algorithm certificates. Smooth migration from classical to post-quantum.
      </FeatureCard>
      <FeatureCard title="CLI-First" icon="⚡">
        Single binary, no dependencies. Script everything. Perfect for automation and DevOps.
      </FeatureCard>
      <FeatureCard title="Interoperable" icon="🔗">
        Tested with OpenSSL, BouncyCastle, and more. Standards-compliant X.509 certificates.
      </FeatureCard>
    </CardGrid>
  </section>

  <!-- Quick Start Code -->
  <section class="landing-code-section">
    <h2>Install</h2>
    <PackageManagerCommand />
  </section>

  <!-- CLI Demo -->
  <section class="landing-section" style="text-align: center;">
    <h2>Quick Start</h2>
    <div class="landing-code-block">
      <div><span class="prompt">$</span> <span class="command">qpki ca init --profile pqc-root-ca.yaml --var cn="My PQC Root"</span></div>
      <div><span class="prompt">$</span> <span class="command">qpki cert issue --profile pqc-server.yaml --cn "server.example.com"</span></div>
      <div><span class="prompt">$</span> <span class="command">qpki ocsp serve --port 8080</span></div>
    </div>
  </section>

  <!-- Standards -->
  <section class="landing-section">
    <h2>Standards Compliant</h2>
    <p>Built on NIST post-quantum cryptography standards and industry PKI specifications.</p>
    <div class="landing-standards-grid stagger-children">
      <StandardBadge>FIPS 203 (ML-KEM)</StandardBadge>
      <StandardBadge>FIPS 204 (ML-DSA)</StandardBadge>
      <StandardBadge>FIPS 205 (SLH-DSA)</StandardBadge>
      <StandardBadge variant="default">RFC 5280 (X.509)</StandardBadge>
      <StandardBadge variant="default">RFC 6960 (OCSP)</StandardBadge>
      <StandardBadge variant="default">RFC 3161 (TSA)</StandardBadge>
      <StandardBadge variant="default">RFC 5652 (CMS)</StandardBadge>
    </div>
  </section>

  <!-- Footer -->
  <footer class="landing-footer">
    <p>
      Open source under Apache 2.0 license.
      <a href="https://github.com/remiblancher/post-quantum-pki">Contribute on GitHub</a>
    </p>
  </footer>
</body>
</html>
