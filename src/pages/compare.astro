---
/**
 * QentriQ Compare Page
 * Redesigned with Biome-inspired design system
 */
import Header from '../components/Header.astro';
import '../styles/tokens.css';
import '../styles/landing.css';
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Compare QentriQ with other post-quantum PKI solutions: OpenSSL, BouncyCastle, liboqs." />
  <title>Compare - QentriQ</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    .compare-content {
      max-width: 1100px;
      margin: 0 auto;
      padding: var(--q-space-16, 4rem) var(--q-space-8, 2rem);
    }

    .compare-section {
      margin-bottom: var(--q-space-16, 4rem);
    }

    .compare-section h2 {
      font-size: 1.75rem;
      margin-bottom: var(--q-space-4, 1rem);
      color: var(--sl-color-accent-high, #60a5fa);
    }

    :root[data-theme='light'] .compare-section h2 {
      color: var(--sl-color-accent, #0065da);
    }

    .compare-section > p {
      color: var(--q-gray-6, #98989f);
      margin-bottom: var(--q-space-6, 1.5rem);
    }

    :root[data-theme='light'] .compare-section > p {
      color: var(--q-gray-5, #64646c);
    }

    /* Table */
    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      margin: var(--q-space-8, 2rem) 0;
      font-size: 0.95rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: var(--q-space-4, 1rem);
      text-align: left;
      border-bottom: 1px solid var(--q-gray-4, rgba(255, 255, 255, 0.1));
    }

    :root[data-theme='light'] .comparison-table th,
    :root[data-theme='light'] .comparison-table td {
      border-bottom-color: var(--q-gray-7, #dadadc);
    }

    .comparison-table th {
      background: var(--q-gray-3, rgba(255, 255, 255, 0.05));
      font-weight: 600;
      position: sticky;
      top: 0;
    }

    :root[data-theme='light'] .comparison-table th {
      background: var(--q-gray-7, #dadadc);
    }

    .comparison-table td:first-child {
      font-weight: 500;
    }

    .comparison-table tr:hover {
      background: var(--q-gray-3, rgba(255, 255, 255, 0.02));
    }

    :root[data-theme='light'] .comparison-table tr:hover {
      background: var(--q-gray-8, #f4f4f5);
    }

    .check {
      color: var(--q-color-success, #22c55e);
      font-weight: bold;
    }

    .partial {
      color: var(--q-color-warning, #eab308);
    }

    .no {
      color: var(--q-gray-5, #64646c);
    }

    .highlight {
      background: rgba(52, 71, 255, 0.1);
    }

    .highlight th,
    .highlight td:first-child {
      color: var(--sl-color-accent-high, #60a5fa);
    }

    :root[data-theme='light'] .highlight {
      background: rgba(0, 101, 218, 0.1);
    }

    :root[data-theme='light'] .highlight th,
    :root[data-theme='light'] .highlight td:first-child {
      color: var(--sl-color-accent, #0065da);
    }

    /* Note */
    .note {
      background: var(--q-gray-3, rgba(255, 255, 255, 0.02));
      border-left: 3px solid var(--sl-color-accent, #3447ff);
      padding: var(--q-space-4, 1rem) var(--q-space-6, 1.5rem);
      margin: var(--q-space-8, 2rem) 0;
      font-size: 0.95rem;
      color: var(--q-gray-6, #98989f);
      border-radius: 0 var(--q-radius-md, 0.5rem) var(--q-radius-md, 0.5rem) 0;
    }

    :root[data-theme='light'] .note {
      background: var(--q-gray-8, #f4f4f5);
      color: var(--q-gray-4, #27272a);
    }

    /* List */
    .compare-list {
      color: var(--q-gray-6, #98989f);
      margin-left: var(--q-space-6, 1.5rem);
    }

    :root[data-theme='light'] .compare-list {
      color: var(--q-gray-5, #64646c);
    }

    .compare-list li {
      margin-bottom: var(--q-space-2, 0.5rem);
    }

    /* CTA */
    .cta {
      text-align: center;
      padding: var(--q-space-12, 3rem);
      background: rgba(52, 71, 255, 0.1);
      border-radius: var(--q-radius-xl, 1rem);
      margin-top: var(--q-space-8, 2rem);
    }

    :root[data-theme='light'] .cta {
      background: rgba(0, 101, 218, 0.1);
    }

    .cta h2 {
      margin-bottom: var(--q-space-4, 1rem);
      color: var(--q-gray-8, #f4f4f5);
    }

    :root[data-theme='light'] .cta h2 {
      color: var(--q-gray-1, #020202);
    }

    .cta p {
      color: var(--q-gray-6, #98989f);
      margin-bottom: var(--q-space-6, 1.5rem);
    }

    :root[data-theme='light'] .cta p {
      color: var(--q-gray-5, #64646c);
    }

    @media (max-width: 768px) {
      .comparison-table {
        font-size: 0.85rem;
      }

      .comparison-table th,
      .comparison-table td {
        padding: var(--q-space-3, 0.75rem) var(--q-space-2, 0.5rem);
      }
    }
  </style>
</head>

<body class="landing-page">
  <Header />

  <!-- Hero -->
  <section class="landing-hero">
    <h1 class="animate-in">Compare Solutions</h1>
    <p class="animate-in" style="animation-delay: 0.1s">
      How QentriQ compares to other post-quantum cryptography implementations
      for PKI and certificate management.
    </p>
  </section>

  <div class="compare-content">
    <section class="compare-section">
      <h2>Feature Comparison</h2>
      <p>A side-by-side comparison of post-quantum PKI capabilities.</p>

      <table class="comparison-table">
        <thead>
          <tr>
            <th>Feature</th>
            <th class="highlight">QentriQ</th>
            <th>OpenSSL 3.x</th>
            <th>BouncyCastle</th>
            <th>liboqs</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Pure implementation (no C deps)</td>
            <td class="highlight"><span class="check">Yes (Go)</span></td>
            <td><span class="no">No (C)</span></td>
            <td><span class="check">Yes (Java)</span></td>
            <td><span class="no">No (C)</span></td>
          </tr>
          <tr>
            <td>Single binary deployment</td>
            <td class="highlight"><span class="check">Yes</span></td>
            <td><span class="no">No</span></td>
            <td><span class="no">No (JVM)</span></td>
            <td><span class="no">No</span></td>
          </tr>
          <tr>
            <td>CLI-first design</td>
            <td class="highlight"><span class="check">Yes</span></td>
            <td><span class="partial">Partial</span></td>
            <td><span class="no">No (API)</span></td>
            <td><span class="no">No (API)</span></td>
          </tr>
          <tr>
            <td>Complete PKI toolkit</td>
            <td class="highlight"><span class="check">CA, OCSP, TSA, CMS</span></td>
            <td><span class="partial">Partial</span></td>
            <td><span class="partial">Library only</span></td>
            <td><span class="no">Crypto only</span></td>
          </tr>
          <tr>
            <td>ML-DSA (FIPS 204)</td>
            <td class="highlight"><span class="check">Yes</span></td>
            <td><span class="check">Yes (3.5+)</span></td>
            <td><span class="check">Yes</span></td>
            <td><span class="check">Yes</span></td>
          </tr>
          <tr>
            <td>ML-KEM (FIPS 203)</td>
            <td class="highlight"><span class="check">Yes</span></td>
            <td><span class="check">Yes (3.5+)</span></td>
            <td><span class="check">Yes</span></td>
            <td><span class="check">Yes</span></td>
          </tr>
          <tr>
            <td>SLH-DSA (FIPS 205)</td>
            <td class="highlight"><span class="check">Yes</span></td>
            <td><span class="check">Yes (3.5+)</span></td>
            <td><span class="check">Yes</span></td>
            <td><span class="check">Yes</span></td>
          </tr>
          <tr>
            <td>Hybrid Certificates (Catalyst)</td>
            <td class="highlight"><span class="check">Yes</span></td>
            <td><span class="partial">Manual</span></td>
            <td><span class="check">Yes</span></td>
            <td><span class="no">No</span></td>
          </tr>
          <tr>
            <td>Composite Signatures</td>
            <td class="highlight"><span class="check">IETF draft-13</span></td>
            <td><span class="no">No</span></td>
            <td><span class="check">Yes</span></td>
            <td><span class="no">No</span></td>
          </tr>
          <tr>
            <td>HSM Support (PKCS#11)</td>
            <td class="highlight"><span class="check">Yes</span></td>
            <td><span class="check">Yes</span></td>
            <td><span class="partial">Via JCA</span></td>
            <td><span class="no">No</span></td>
          </tr>
          <tr>
            <td>OCSP Responder</td>
            <td class="highlight"><span class="check">Built-in</span></td>
            <td><span class="check">Yes</span></td>
            <td><span class="no">No</span></td>
            <td><span class="no">No</span></td>
          </tr>
          <tr>
            <td>TSA Server</td>
            <td class="highlight"><span class="check">Built-in</span></td>
            <td><span class="partial">Partial</span></td>
            <td><span class="no">No</span></td>
            <td><span class="no">No</span></td>
          </tr>
          <tr>
            <td>COSE/CWT Tokens</td>
            <td class="highlight"><span class="check">Yes</span></td>
            <td><span class="no">No</span></td>
            <td><span class="partial">Partial</span></td>
            <td><span class="no">No</span></td>
          </tr>
          <tr>
            <td>Learning Resources</td>
            <td class="highlight"><span class="check">QLAB Journey</span></td>
            <td><span class="partial">Docs only</span></td>
            <td><span class="partial">Docs only</span></td>
            <td><span class="partial">Docs only</span></td>
          </tr>
          <tr>
            <td>License</td>
            <td class="highlight">Apache 2.0</td>
            <td>Apache 2.0</td>
            <td>MIT</td>
            <td>MIT</td>
          </tr>
        </tbody>
      </table>

      <div class="note">
        <strong>Note:</strong> This comparison is based on publicly available information as of February 2025.
        Features and capabilities may have changed. We encourage you to verify current status with each project.
      </div>
    </section>

    <section class="compare-section">
      <h2>When to Choose QentriQ</h2>
      <p>QentriQ is ideal when you need:</p>
      <ul class="compare-list">
        <li>A complete, ready-to-use PKI solution (not just a crypto library)</li>
        <li>Easy deployment with a single binary and no external dependencies</li>
        <li>CLI-first workflow for automation and DevOps integration</li>
        <li>Hybrid certificate support for gradual migration</li>
        <li>A learning path to understand post-quantum PKI concepts</li>
      </ul>
    </section>

    <div class="cta">
      <h2>Ready to Get Started?</h2>
      <p>Try QentriQ and build your first quantum-safe certificate in minutes.</p>
      <a href="/qpki/getting-started/quick-start/" class="btn btn-primary">
        Read the Documentation
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Footer -->
  <footer class="landing-footer">
    <p>
      Open source under Apache 2.0 license.
      <a href="https://github.com/remiblancher/post-quantum-pki">Contribute on GitHub</a>
    </p>
  </footer>
</body>
</html>
