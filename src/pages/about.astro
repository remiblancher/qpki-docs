---
/**
 * QentriQ About Page
 * Redesigned with Biome-inspired design system
 */
import FeatureCard from '../components/FeatureCard.astro';
import CardGrid from '../components/CardGrid.astro';
import Header from '../components/Header.astro';
import '../styles/tokens.css';
import '../styles/landing.css';
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="About QentriQ - Open-source Quantum-Safe PKI suite for the post-quantum era." />
  <title>About - QentriQ</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    .about-content {
      max-width: 900px;
      margin: 0 auto;
      padding: var(--q-space-16, 4rem) var(--q-space-8, 2rem);
    }

    .about-section {
      margin-bottom: var(--q-space-16, 4rem);
    }

    .about-section h2 {
      font-size: 1.75rem;
      margin-bottom: var(--q-space-6, 1.5rem);
      color: var(--sl-color-accent-high, #60a5fa);
    }

    .about-section p {
      color: var(--q-gray-6, #98989f);
      margin-bottom: var(--q-space-4, 1rem);
      font-size: 1.1rem;
    }

    :root[data-theme='light'] .about-section p {
      color: var(--q-gray-5, #64646c);
    }

    :root[data-theme='light'] .about-section h2 {
      color: var(--sl-color-accent, #0065da);
    }

    /* Timeline */
    .timeline {
      position: relative;
      padding-left: var(--q-space-8, 2rem);
      border-left: 2px solid var(--sl-color-accent, #3447ff);
      margin-top: var(--q-space-8, 2rem);
    }

    .timeline-item {
      margin-bottom: var(--q-space-8, 2rem);
      position: relative;
    }

    .timeline-item::before {
      content: '';
      position: absolute;
      left: calc(-2rem - 5px);
      top: 0.25rem;
      width: 12px;
      height: 12px;
      background: var(--sl-color-accent, #3447ff);
      border-radius: 50%;
    }

    .timeline-item h3 {
      font-size: 1.1rem;
      margin-bottom: var(--q-space-2, 0.5rem);
      color: var(--q-gray-8, #f4f4f5);
    }

    :root[data-theme='light'] .timeline-item h3 {
      color: var(--q-gray-1, #020202);
    }

    .timeline-item .date {
      color: var(--sl-color-accent-high, #60a5fa);
      font-size: 0.9rem;
      margin-bottom: var(--q-space-2, 0.5rem);
      font-weight: 600;
    }

    :root[data-theme='light'] .timeline-item .date {
      color: var(--sl-color-accent, #0065da);
    }

    .timeline-item p {
      font-size: 1rem;
    }

    /* Projects */
    .project-card {
      background: var(--q-gray-3, #202022);
      border: 1px solid var(--q-gray-4, #27272a);
      border-radius: var(--q-radius-lg, 0.75rem);
      padding: var(--q-space-6, 1.5rem);
      transition: border-color var(--q-transition-normal, 200ms ease);
    }

    .project-card:hover {
      border-color: var(--sl-color-accent, #3447ff);
    }

    :root[data-theme='light'] .project-card {
      background: #ffffff;
      border-color: #d4d4d4;
    }

    .project-card h3 {
      font-size: 1.25rem;
      margin-bottom: var(--q-space-2, 0.5rem);
      color: var(--q-gray-8, #f4f4f5);
    }

    :root[data-theme='light'] .project-card h3 {
      color: var(--q-gray-1, #020202);
    }

    .project-card p {
      color: var(--q-gray-6, #98989f);
      margin-bottom: var(--q-space-4, 1rem);
    }

    :root[data-theme='light'] .project-card p {
      color: var(--q-gray-5, #64646c);
    }

    .project-card a {
      color: var(--sl-color-accent-high, #60a5fa);
      font-size: 0.9rem;
    }

    .project-card a:hover {
      text-decoration: underline;
    }

    :root[data-theme='light'] .project-card a {
      color: var(--sl-color-accent, #0065da);
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--q-space-6, 1.5rem);
      margin-top: var(--q-space-8, 2rem);
    }
  </style>
</head>

<body class="landing-page">
  <Header />

  <!-- Hero -->
  <section class="landing-hero">
    <h1 class="animate-in">About QentriQ</h1>
    <p class="animate-in" style="animation-delay: 0.1s">
      An open-source initiative to make quantum-safe PKI accessible to everyone,
      preparing organizations for the post-quantum cryptography transition.
    </p>
  </section>

  <div class="about-content">
    <!-- Vision -->
    <section class="about-section">
      <h2>Our Vision</h2>
      <p>
        Quantum computers will eventually break the cryptographic algorithms that secure today's digital infrastructure.
        QentriQ exists to ensure that organizations of all sizes can prepare for this transition with production-ready,
        open-source tools.
      </p>
      <CardGrid columns={3}>
        <FeatureCard title="Accessible">
          No expensive licenses, no vendor lock-in. Pure open-source under Apache 2.0 license.
        </FeatureCard>
        <FeatureCard title="Standards-First">
          Built on NIST FIPS 203/204/205 and IETF RFCs. No proprietary extensions.
        </FeatureCard>
        <FeatureCard title="Production-Ready">
          Not a research project. Designed for real-world deployment with HSM support and audit logging.
        </FeatureCard>
      </CardGrid>
    </section>

    <!-- The Suite -->
    <section class="about-section">
      <h2>The Suite</h2>
      <div class="projects-grid">
        <div class="project-card">
          <h3>QPKI</h3>
          <p>Complete post-quantum PKI toolkit: CA, OCSP, TSA, CMS, and more. Single binary, CLI-first.</p>
          <a href="https://github.com/remiblancher/post-quantum-pki">github.com/remiblancher/post-quantum-pki</a>
        </div>
        <div class="project-card">
          <h3>QLAB</h3>
          <p>Hands-on learning journey from quantum threats to production-ready crypto-agile infrastructure.</p>
          <a href="https://github.com/remiblancher/post-quantum-pki-lab">github.com/remiblancher/post-quantum-pki-lab</a>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="about-section">
      <h2>Timeline</h2>
      <p>Key milestones in the post-quantum transition:</p>
      <div class="timeline">
        <div class="timeline-item">
          <div class="date">August 2024</div>
          <h3>NIST PQC Standards Published</h3>
          <p>FIPS 203 (ML-KEM), FIPS 204 (ML-DSA), FIPS 205 (SLH-DSA) officially released.</p>
        </div>
        <div class="timeline-item">
          <div class="date">2025</div>
          <h3>CNSA 2.0 Phase 1</h3>
          <p>NSA recommends starting migration planning for national security systems.</p>
        </div>
        <div class="timeline-item">
          <div class="date">2030</div>
          <h3>CNSA 2.0 Phase 2</h3>
          <p>Hybrid solutions required. Classical-only signatures deprecated for NSS.</p>
        </div>
        <div class="timeline-item">
          <div class="date">2033</div>
          <h3>CNSA 2.0 Phase 3</h3>
          <p>Full post-quantum required. Classical algorithms no longer approved.</p>
        </div>
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer class="landing-footer">
    <p>
      Open source under Apache 2.0 license.
      <a href="https://github.com/remiblancher/post-quantum-pki">Contribute on GitHub</a>
    </p>
  </footer>
</body>
</html>
