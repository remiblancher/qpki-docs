---
/**
 * QlabSection - Interactive learning playground CTA
 * Shows lab progression from beginner to expert
 */
---

<section class="qlab-section not-content">
  <div class="section-inner">
    <div class="qlab-card fade-in">
      <div class="qlab-content">
        <span class="qlab-badge">Interactive Labs</span>
        <h2>Learn by Doing</h2>
        <p>QLAB is a hands-on learning journey through post-quantum cryptography. 11 labs from quantum threat awareness to crypto-agility and migration strategy.</p>

        <div class="lab-progress">
          <div class="lab-dots">
            <span class="lab-dot completed"></span>
            <span class="lab-dot completed"></span>
            <span class="lab-dot completed"></span>
            <span class="lab-dot active"></span>
            <span class="lab-dot"></span>
            <span class="lab-dot"></span>
          </div>
          <div class="lab-labels">
            <span class="lab-name completed">Quantum Threat</span>
            <span class="lab-name completed">First Certificate</span>
            <span class="lab-name completed">Full PQ Chain</span>
            <span class="lab-name active">Hybrid Mode</span>
            <span class="lab-name">Revocation</span>
            <span class="lab-name">+6 more</span>
          </div>
        </div>

        <div class="qlab-actions">
          <a href="/qlab/overview/" class="q-btn q-btn-accent">Start the Labs</a>
          <a href="https://github.com/remiblancher/qlab" class="q-btn q-btn-secondary"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg> GitHub</a>
        </div>
      </div>

      <div class="qlab-visual">
        <div class="modules-grid">
          <div class="module-item">
            <svg class="module-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4l3 3" stroke="#FF55A3" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span class="module-name">Awareness</span>
            <span class="module-count">2 labs</span>
          </div>
          <div class="module-item">
            <svg class="module-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h16M6 16h12M8 12h8M10 8h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 4v4" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span class="module-name">Build</span>
            <span class="module-count">2 labs</span>
          </div>
          <div class="module-item">
            <svg class="module-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span class="module-name">Lifecycle</span>
            <span class="module-count">2 labs</span>
          </div>
          <div class="module-item">
            <svg class="module-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" stroke="currentColor" stroke-width="1.5"/><path d="M9 12l2 2 4-4" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="module-name">Signatures</span>
            <span class="module-count">3 labs</span>
          </div>
          <div class="module-item">
            <svg class="module-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M8 12h8M12 8v8" stroke="#FF55A3" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span class="module-name">Encryption</span>
            <span class="module-count">1 lab</span>
          </div>
          <div class="module-item">
            <svg class="module-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M8 7h12M8 12h12M8 17h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="4" cy="7" r="1.5" fill="#eab308"/><circle cx="4" cy="12" r="1.5" fill="#eab308"/><circle cx="4" cy="17" r="1.5" fill="#eab308"/></svg>
            <span class="module-name">Migration</span>
            <span class="module-count">1 lab</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .qlab-section {
    padding: 5rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .qlab-card {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    align-items: center;
    padding: 3rem;
    border-radius: 20px;
    border: 1px solid rgba(0, 91, 197, 0.15);
    background: linear-gradient(135deg, rgba(0, 91, 197, 0.05), rgba(255, 85, 163, 0.03));
  }

  .qlab-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background: rgba(0, 91, 197, 0.1);
    color: #60a5fa;
    border: 1px solid rgba(0, 91, 197, 0.25);
    margin-bottom: 1.25rem;
  }

  .qlab-content h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin-bottom: 0.75rem;
  }

  .qlab-content p {
    color: var(--sl-color-gray-3);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  /* Lab progress */
  .lab-progress {
    margin-bottom: 2rem;
  }

  .lab-dots {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    padding: 0 4px;
    margin-bottom: 0.5rem;
  }

  /* Connecting line behind dots */
  .lab-dots::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 4px;
    right: 4px;
    height: 2px;
    background: var(--sl-color-gray-5);
    transform: translateY(-50%);
  }

  /* Green progress overlay */
  .lab-dots::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 4px;
    width: 50%;
    height: 2px;
    background: linear-gradient(90deg, #22c55e 85%, var(--sl-color-gray-5) 100%);
    transform: translateY(-50%);
  }

  .lab-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--sl-color-gray-5);
    position: relative;
    z-index: 1;
  }

  .lab-dot.completed {
    background: #22c55e;
  }

  .lab-dot.active {
    background: #FF55A3;
    box-shadow: 0 0 10px rgba(255, 85, 163, 0.4);
  }

  .lab-labels {
    display: flex;
    justify-content: space-between;
  }

  .lab-name {
    font-size: 0.65rem;
    color: var(--sl-color-gray-4);
    white-space: nowrap;
    text-align: center;
    flex: 1;
  }

  .lab-name.active {
    color: #FF55A3;
    font-weight: 600;
  }

  .lab-name.completed {
    color: var(--sl-color-gray-3);
  }

  .qlab-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Modules grid */
  .qlab-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    width: 100%;
  }

  .module-item {
    display: grid;
    grid-template-columns: 24px 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
    transition: all 0.2s ease;
  }

  .module-item:hover {
    border-color: rgba(0, 91, 197, 0.25);
    background: rgba(0, 91, 197, 0.04);
  }

  .module-icon {
    color: var(--sl-color-gray-4);
    width: 24px;
    height: 24px;
  }

  .module-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .module-count {
    font-size: 0.7rem;
    color: var(--sl-color-gray-4);
    white-space: nowrap;
    text-align: right;
  }

  /* Light mode */
  :root[data-theme='light'] .qlab-card {
    background: linear-gradient(135deg, rgba(0, 91, 197, 0.03), rgba(255, 85, 163, 0.02));
  }

  :root[data-theme='light'] .module-item {
    background: rgba(0, 0, 0, 0.02);
    border-color: rgba(0, 0, 0, 0.06);
  }

  :root[data-theme='light'] .module-item:hover {
    background: rgba(0, 91, 197, 0.03);
    border-color: rgba(0, 91, 197, 0.15);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .qlab-card {
      grid-template-columns: 1fr;
      padding: 2rem;
    }

    .modules-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
    }

    .module-item {
      padding: 0.6rem 0.75rem;
      gap: 0.5rem;
    }

    .module-icon {
      width: 18px;
      height: 18px;
    }

    .module-name {
      font-size: 0.75rem;
    }

    .module-count {
      font-size: 0.6rem;
    }

    .lab-labels {
      display: none;
    }
  }
</style>
