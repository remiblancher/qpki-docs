---
/**
 * OpenSourceCTA - Open source call to action with GitHub stats
 * Fetches real stats from GitHub API at build time
 */
let stars = 0;
let forks = 0;
let latestRelease = '';

try {
  const res = await fetch('https://api.github.com/repos/remiblancher/qpki', {
    headers: { 'Accept': 'application/vnd.github.v3+json' },
  });
  if (res.ok) {
    const data = await res.json();
    stars = data.stargazers_count ?? 0;
    forks = data.forks_count ?? 0;
  }
} catch (_) {}

try {
  const res = await fetch('https://api.github.com/repos/remiblancher/qpki/releases/latest', {
    headers: { 'Accept': 'application/vnd.github.v3+json' },
  });
  if (res.ok) {
    const data = await res.json();
    latestRelease = data.tag_name ?? '';
  }
} catch (_) {}
---

<section class="oss-section not-content">
  <div class="section-inner">
    <div class="oss-card fade-in">
      <div class="oss-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" fill="currentColor"/>
        </svg>
      </div>
      <h2>Open Source</h2>
      <p>QPKI is free and open source. Built in Go, licensed under Apache 2.0. Contributions welcome.</p>

      <div class="oss-stats">
        {stars > 0 && (
          <div class="stat">
            <span class="stat-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1l2.5 5 5.5.8-4 3.9.9 5.3L8 13.3 3.1 16l.9-5.3-4-3.9 5.5-.8L8 1z" fill="#eab308"/></svg>
            </span>
            <span class="stat-value">{stars}</span>
            <span class="stat-label">Stars</span>
          </div>
        )}
        {forks > 0 && (
          <div class="stat">
            <span class="stat-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M5 3v4M5 11v2M11 3v2M11 9v4M5 7a2 2 0 104 0H5zM11 5a2 2 0 10-4 0h4z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            </span>
            <span class="stat-value">{forks}</span>
            <span class="stat-label">Forks</span>
          </div>
        )}
        {latestRelease && (
          <div class="stat">
            <span class="stat-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 2v12l4-3 4 3V2H4z" stroke="#FF55A3" stroke-width="1.2" fill="none"/></svg>
            </span>
            <span class="stat-value">{latestRelease}</span>
            <span class="stat-label">Latest</span>
          </div>
        )}
        <div class="stat">
          <span class="stat-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="5" cy="6" r="2" stroke="currentColor" stroke-width="1.2"/><circle cx="11" cy="6" r="2" stroke="currentColor" stroke-width="1.2"/><path d="M1 14c0-2.2 1.8-4 4-4s4 1.8 4 4M7 14c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="1.2"/></svg>
          </span>
          <span class="stat-label">Go · Apache 2.0</span>
        </div>
      </div>

      <a href="https://github.com/remiblancher/qpki" class="q-btn q-btn-secondary" target="_blank" rel="noopener">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        View on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .oss-section {
    padding: 5rem 1.5rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .oss-card {
    text-align: center;
    padding: 3rem 2rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
  }

  .oss-icon {
    color: var(--sl-color-gray-2);
    margin-bottom: 1.5rem;
  }

  .oss-card h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin-bottom: 0.75rem;
  }

  .oss-card > p {
    color: var(--sl-color-gray-3);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 420px;
    margin: 0 auto 2rem;
  }

  .oss-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
  }

  .stat-value {
    font-weight: 700;
    color: var(--sl-color-white);
    font-size: 1rem;
  }

  .stat-icon {
    display: flex;
    align-items: center;
    color: var(--sl-color-gray-4);
  }


  /* Light mode */
  :root[data-theme='light'] .oss-card {
    background: rgba(0, 0, 0, 0.02);
    border-color: rgba(0, 0, 0, 0.08);
  }

</style>
