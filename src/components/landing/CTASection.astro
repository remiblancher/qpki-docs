---
/**
 * CTASection - Trusted by logos
 */
---

<section class="cta-section not-content fade-in">
  <div class="trusted-by">
    <span class="trusted-label">They use QPKI</span>
    <div class="trusted-logos">
      <a href="https://skedl.fr" target="_blank" rel="noopener noreferrer" class="trusted-logo">
        <img src="/images/logos/skedl.png" alt="Skedl" class="logo-img" width="102" height="28" />
      </a>
    </div>
    <a href="https://github.com/qpki/qpki/issues/new?title=Add+my+company+to+%22They+use+QPKI%22&body=Company%3A+%0ALogo+URL+or+attachment%3A+%0AWebsite%3A+%0A" target="_blank" rel="noopener noreferrer" class="add-yours">Using QPKI? Add your company &rarr;</a>
  </div>
</section>

<style>
  .cta-section {
    padding: 4rem 1.5rem;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .trusted-by {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .trusted-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--sl-color-gray-5);
    font-weight: 600;
  }

  .trusted-logos {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .trusted-logo {
    display: flex;
    align-items: center;
    opacity: 0.9;
    transition: opacity 0.2s ease;
  }

  .trusted-logo:hover {
    opacity: 1;
  }

  .logo-img {
    height: 28px;
    width: auto;
  }

  .add-yours {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-4);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .add-yours:hover {
    color: var(--sl-color-accent);
  }

  .trusted-sep {
    width: 1px;
    height: 1.25rem;
    background: var(--sl-color-gray-5);
  }
</style>
