---
/**
 * TrustBar - Horizontal bar of compliance badges
 * FIPS standards + RFC specs
 */
---

<section class="trust-bar not-content">
  <div class="trust-inner">
    <span class="trust-label">Standards</span>
    <div class="trust-badges">
      <a class="badge badge-fips" href="https://csrc.nist.gov/pubs/fips/203/final" target="_blank" rel="noopener noreferrer">FIPS 203 <span class="badge-sub">ML-KEM</span></a>
      <a class="badge badge-fips" href="https://csrc.nist.gov/pubs/fips/204/final" target="_blank" rel="noopener noreferrer">FIPS 204 <span class="badge-sub">ML-DSA</span></a>
      <a class="badge badge-fips" href="https://csrc.nist.gov/pubs/fips/205/final" target="_blank" rel="noopener noreferrer">FIPS 205 <span class="badge-sub">SLH-DSA</span></a>
      <span class="badge-sep"></span>
      <a class="badge badge-rfc" href="https://datatracker.ietf.org/doc/html/rfc5280" target="_blank" rel="noopener noreferrer">RFC 5280 <span class="badge-sub">X.509</span></a>
      <a class="badge badge-rfc" href="https://datatracker.ietf.org/doc/html/rfc9881" target="_blank" rel="noopener noreferrer">RFC 9881</a>
      <a class="badge badge-rfc" href="https://datatracker.ietf.org/doc/html/rfc9909" target="_blank" rel="noopener noreferrer">RFC 9909</a>
      <a class="badge badge-rfc" href="https://datatracker.ietf.org/doc/html/rfc9883" target="_blank" rel="noopener noreferrer">RFC 9883</a>
      <a class="badge badge-rfc" href="https://datatracker.ietf.org/doc/html/rfc9882" target="_blank" rel="noopener noreferrer">RFC 9882</a>
      <a class="badge badge-rfc" href="https://datatracker.ietf.org/doc/html/rfc9814" target="_blank" rel="noopener noreferrer">RFC 9814</a>
      <span class="badge-sep"></span>
      <a class="badge badge-itu" href="https://www.itu.int/rec/T-REC-X.509" target="_blank" rel="noopener noreferrer">ITU-T X.509 <span class="badge-sub">Catalyst</span></a>
      <a class="badge badge-draft" href="https://datatracker.ietf.org/doc/draft-ounsworth-pq-composite-sigs/" target="_blank" rel="noopener noreferrer">Composite <span class="badge-sub">draft</span></a>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1.25rem 1.5rem;
    margin: 0 auto;
    max-width: 900px;
  }

  .trust-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .trust-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--sl-color-gray-3);
    font-weight: 600;
  }

  .trust-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .badge {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    white-space: nowrap;
    text-decoration: none;
    transition: all var(--q-transition-normal, 0.2s ease);
  }

  .badge-fips {
    border: 1px solid rgba(255, 85, 163, 0.25);
    color: var(--sl-color-accent-high);
    background: rgba(255, 85, 163, 0.05);
  }

  .badge-fips:hover {
    border-color: rgba(255, 85, 163, 0.5);
    background: rgba(255, 85, 163, 0.1);
  }

  .badge-sub {
    color: var(--sl-color-gray-2);
    font-weight: 400;
    margin-left: 2px;
  }

  .badge-rfc {
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
    background: transparent;
  }

  .badge-rfc:hover {
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-gray-2);
  }

  .badge-itu {
    border: 1px solid rgba(34, 197, 94, 0.25);
    color: #22c55e;
    background: rgba(34, 197, 94, 0.05);
  }

  .badge-itu:hover {
    border-color: rgba(34, 197, 94, 0.5);
    background: rgba(34, 197, 94, 0.1);
  }

  .badge-draft {
    border: 1px dashed var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
    background: transparent;
    opacity: 0.85;
  }

  .badge-draft:hover {
    opacity: 0.85;
    border-color: var(--sl-color-gray-4);
  }

  .badge-sep {
    width: 1px;
    height: 1.25rem;
    background: var(--sl-color-gray-5);
    margin: 0 0.25rem;
  }

  /* Light mode */
  :root[data-theme='light'] .trust-bar {
    border-color: rgba(0, 0, 0, 0.06);
  }

  :root[data-theme='light'] .badge-fips {
    background: rgba(255, 85, 163, 0.04);
  }

  @media (max-width: 640px) {
    .trust-label {
      width: 100%;
      text-align: center;
    }
    .badge-sep {
      display: none;
    }
  }
</style>
