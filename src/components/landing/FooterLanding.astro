---
/**
 * FooterLanding - Rich multi-column footer
 */
---

<footer class="landing-footer not-content">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <div class="brand-logo">
          <svg width="28" height="28" viewBox="140 135 220 220" fill="none" aria-hidden="true">
            <circle cx="329.38" cy="324.72" r="21.74" fill="#FF55A3"/>
            <path d="M292.36,298.92c-5.73-5.73-14.48-7.72-21.81-4.27a59.6,59.6,0,0,1-68.71-94.78c14.42-15.37,35.62-22.08,57.28-17.31A57.9,57.9,0,0,1,286,197.13c.5.46,1,.92,1.45,1.4A59.73,59.73,0,0,1,299.26,266c-3.42,7.29-1.36,16,4.33,21.69h0A20,20,0,0,0,335.88,282c17.26-37.92,9.54-84.33-22.35-114A99.7,99.7,0,0,0,174.78,311.13c.76.75,1.52,1.49,2.3,2.23A99.76,99.76,0,0,0,287,331.23c12.5-5.77,15.22-22.43,5.48-32.16Z" class="footer-q"/>
          </svg>
          <span class="brand-name">QPKI</span>
        </div>
        <p class="brand-desc">Post-quantum PKI toolkit.<br>Open source. Standards-compliant.</p>
        <a href="mailto:remi.blancher@proton.me" class="brand-contact">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M22 4L12 13 2 4"/>
          </svg>
          Contact us
        </a>
      </div>

      <!-- Product -->
      <div class="footer-col">
        <p class="footer-col-title">Product</p>
        <ul>
          <li><a href="/qpki/getting-started/quick-start/">Quick Start</a></li>
          <li><a href="/qpki/getting-started/installation/">Installation</a></li>
          <li><a href="/qpki/reference/cli/">CLI Reference</a></li>
          <li><a href="/qlab/overview/">QLAB Playground</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div class="footer-col">
        <p class="footer-col-title">Resources</p>
        <ul>
          <li><a href="/qpki/getting-started/post-quantum/">Post-Quantum Guide</a></li>
          <li><a href="/qpki/migration/crypto-agility/">Crypto-Agility</a></li>
          <li><a href="/qpki/reference/standards/">Standards</a></li>
          <li><a href="/qpki/reference/glossary/">Glossary</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div class="footer-col">
        <p class="footer-col-title">Community</p>
        <ul>
          <li><a href="https://github.com/qpki/qpki" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href="/qpki/dev/contributing/">Contributing</a></li>
          <li><a href="/qpki/dev/architecture/">Architecture</a></li>
          <li><a href="https://github.com/qpki/qpki/blob/main/CHANGELOG.md" target="_blank" rel="noopener noreferrer">Changelog</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="copyright">&copy; {new Date().getFullYear()} QentriQ.</span>
    </div>
  </div>
</footer>

<style>
  .landing-footer {
    border-top: 1px solid var(--sl-color-gray-5);
    padding: 4rem 1.5rem 2rem;
    margin-top: 2rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-q {
    fill: #fff;
  }

  :root[data-theme='light'] .footer-q {
    fill: #0B3D91;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .brand-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .brand-desc {
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .brand-contact {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .brand-contact:hover {
    color: #FF55A3;
  }

  .footer-col-title {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-2);
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-col a:hover {
    color: var(--sl-color-white);
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--sl-color-gray-5);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .copyright {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }

  /* Light mode */
  :root[data-theme='light'] .landing-footer {
    border-color: #e8e9eb;
  }

  :root[data-theme='light'] .footer-bottom {
    border-color: #e8e9eb;
  }

  :root[data-theme='light'] .footer-col a:hover {
    color: var(--sl-color-gray-1);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-brand {
      grid-column: span 1;
    }
  }
</style>
