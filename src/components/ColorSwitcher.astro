---
/**
 * ColorSwitcher - Multi-palette selector for comparison
 * Palettes: Rose Quantum, DocKit, Bleu Quantum, Violet, Cyan, Matrix
 */
---

<div class="palette-switcher" id="palette-switcher">
  <button class="palette-toggle" id="palette-toggle" title="Changer de palette">
    <span class="palette-dot"></span>
    <span class="palette-name">Rose Quantum</span>
  </button>
  <div class="palette-menu" id="palette-menu">
    <button class="palette-option" data-palette="rose-quantum">
      <span class="dot" style="background: #E91E63"></span>
      Rose Quantum
    </button>
    <button class="palette-option" data-palette="dockit">
      <span class="dot" style="background: linear-gradient(135deg, #3a1c71, #D76D77, #ffca7b)"></span>
      DocKit
    </button>
    <button class="palette-option" data-palette="quantum-blue">
      <span class="dot" style="background: #3B82F6"></span>
      Bleu Quantum
    </button>
    <button class="palette-option" data-palette="violet">
      <span class="dot" style="background: #8B5CF6"></span>
      Violet Indigo
    </button>
    <button class="palette-option" data-palette="cyan">
      <span class="dot" style="background: #06B6D4"></span>
      Cyan Futuriste
    </button>
    <button class="palette-option" data-palette="matrix">
      <span class="dot" style="background: #22C55E"></span>
      Matrix
    </button>
  </div>
</div>

<style>
  .palette-switcher {
    position: fixed;
    bottom: 20px;
    left: 20px;
    z-index: 9999;
  }

  .palette-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 50px;
    border: 2px solid var(--sl-color-accent, #E91E63);
    background: rgba(0, 0, 0, 0.9);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .palette-toggle:hover {
    transform: scale(1.05);
  }

  .palette-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--sl-color-accent, #E91E63);
  }

  .palette-menu {
    position: absolute;
    bottom: 100%;
    left: 0;
    margin-bottom: 8px;
    background: rgba(0, 0, 0, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 8px;
    display: none;
    flex-direction: column;
    gap: 4px;
    min-width: 180px;
  }

  .palette-menu.open {
    display: flex;
  }

  .palette-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: white;
    font-size: 0.875rem;
    cursor: pointer;
    transition: background 0.15s;
    text-align: left;
  }

  .palette-option:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .palette-option.active {
    background: rgba(255, 255, 255, 0.15);
  }

  .dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Light mode */
  :root[data-theme='light'] .palette-toggle {
    background: rgba(255, 255, 255, 0.95);
    color: #020202;
    border-color: var(--sl-color-accent, #E91E63);
  }

  :root[data-theme='light'] .palette-menu {
    background: rgba(255, 255, 255, 0.98);
    border-color: rgba(0, 0, 0, 0.1);
  }

  :root[data-theme='light'] .palette-option {
    color: #020202;
  }

  :root[data-theme='light'] .palette-option:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  :root[data-theme='light'] .palette-option.active {
    background: rgba(0, 0, 0, 0.08);
  }
</style>

<script is:inline>
  const palettes = {
    'rose-quantum': {
      name: 'Rose Quantum',
      dark: {
        '--sl-color-accent-low': '#4a1a35',
        '--sl-color-accent': '#E91E63',
        '--sl-color-accent-high': '#F48FB1'
      },
      light: {
        '--sl-color-accent-low': '#FCE4EC',
        '--sl-color-accent': '#C2185B',
        '--sl-color-accent-high': '#880E4F'
      },
      gradient: 'linear-gradient(135deg, #880E4F 0%, #E91E63 50%, #F48FB1 100%)',
      bgDark: 'radial-gradient(rgb(74, 26, 53), transparent 50%), radial-gradient(rgb(74, 26, 53), transparent 50%)',
      bgLight: 'radial-gradient(rgb(252, 228, 236), transparent 50%), radial-gradient(rgb(252, 228, 236), transparent 50%)',
      btnColor: '#E91E63',
      btnHover: '#C2185B'
    },
    'dockit': {
      name: 'DocKit',
      dark: {
        '--sl-color-accent-low': '#2d1a22',
        '--sl-color-accent': '#D76D77',
        '--sl-color-accent-high': '#e8a5ac'
      },
      light: {
        '--sl-color-accent-low': '#f5e6e8',
        '--sl-color-accent': '#D76D77',
        '--sl-color-accent-high': '#a85058'
      },
      gradient: 'linear-gradient(135deg, #3a1c71 0%, #D76D77 50%, #ffca7b 100%)',
      bgDark: 'radial-gradient(rgb(58, 28, 113), transparent 50%), radial-gradient(rgb(215, 109, 119), transparent 50%)',
      bgLight: 'radial-gradient(rgb(232, 218, 250), transparent 50%), radial-gradient(rgb(245, 220, 220), transparent 50%)',
      btnColor: '#D76D77',
      btnHover: '#c45d67'
    },
    'quantum-blue': {
      name: 'Bleu Quantum',
      dark: {
        '--sl-color-accent-low': '#1e3a5f',
        '--sl-color-accent': '#3B82F6',
        '--sl-color-accent-high': '#93C5FD'
      },
      light: {
        '--sl-color-accent-low': '#DBEAFE',
        '--sl-color-accent': '#2563EB',
        '--sl-color-accent-high': '#1D4ED8'
      },
      gradient: 'linear-gradient(135deg, #1e3a8a 0%, #3B82F6 50%, #93C5FD 100%)',
      bgDark: 'radial-gradient(rgb(30, 58, 138), transparent 50%), radial-gradient(rgb(59, 130, 246), transparent 50%)',
      bgLight: 'radial-gradient(rgb(219, 234, 254), transparent 50%), radial-gradient(rgb(191, 219, 254), transparent 50%)',
      btnColor: '#3B82F6',
      btnHover: '#2563EB'
    },
    'violet': {
      name: 'Violet Indigo',
      dark: {
        '--sl-color-accent-low': '#2e1065',
        '--sl-color-accent': '#8B5CF6',
        '--sl-color-accent-high': '#C4B5FD'
      },
      light: {
        '--sl-color-accent-low': '#EDE9FE',
        '--sl-color-accent': '#7C3AED',
        '--sl-color-accent-high': '#5B21B6'
      },
      gradient: 'linear-gradient(135deg, #4c1d95 0%, #8B5CF6 50%, #C4B5FD 100%)',
      bgDark: 'radial-gradient(rgb(76, 29, 149), transparent 50%), radial-gradient(rgb(139, 92, 246), transparent 50%)',
      bgLight: 'radial-gradient(rgb(237, 233, 254), transparent 50%), radial-gradient(rgb(221, 214, 254), transparent 50%)',
      btnColor: '#8B5CF6',
      btnHover: '#7C3AED'
    },
    'cyan': {
      name: 'Cyan Futuriste',
      dark: {
        '--sl-color-accent-low': '#083344',
        '--sl-color-accent': '#06B6D4',
        '--sl-color-accent-high': '#67E8F9'
      },
      light: {
        '--sl-color-accent-low': '#CFFAFE',
        '--sl-color-accent': '#0891B2',
        '--sl-color-accent-high': '#0E7490'
      },
      gradient: 'linear-gradient(135deg, #164e63 0%, #06B6D4 50%, #67E8F9 100%)',
      bgDark: 'radial-gradient(rgb(22, 78, 99), transparent 50%), radial-gradient(rgb(6, 182, 212), transparent 50%)',
      bgLight: 'radial-gradient(rgb(207, 250, 254), transparent 50%), radial-gradient(rgb(165, 243, 252), transparent 50%)',
      btnColor: '#06B6D4',
      btnHover: '#0891B2'
    },
    'matrix': {
      name: 'Matrix',
      dark: {
        '--sl-color-accent-low': '#052e16',
        '--sl-color-accent': '#22C55E',
        '--sl-color-accent-high': '#86EFAC'
      },
      light: {
        '--sl-color-accent-low': '#DCFCE7',
        '--sl-color-accent': '#16A34A',
        '--sl-color-accent-high': '#166534'
      },
      gradient: 'linear-gradient(135deg, #14532d 0%, #22C55E 50%, #86EFAC 100%)',
      bgDark: 'radial-gradient(rgb(5, 46, 22), transparent 50%), radial-gradient(rgb(34, 197, 94), transparent 50%)',
      bgLight: 'radial-gradient(rgb(220, 252, 231), transparent 50%), radial-gradient(rgb(187, 247, 208), transparent 50%)',
      btnColor: '#22C55E',
      btnHover: '#16A34A'
    }
  };

  let currentPalette = 'rose-quantum';
  const toggle = document.getElementById('palette-toggle');
  const menu = document.getElementById('palette-menu');
  const paletteName = toggle.querySelector('.palette-name');
  const paletteDot = toggle.querySelector('.palette-dot');
  const options = document.querySelectorAll('.palette-option');

  // Toggle menu
  toggle.addEventListener('click', () => {
    menu.classList.toggle('open');
  });

  // Close menu on click outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.palette-switcher')) {
      menu.classList.remove('open');
    }
  });

  // Apply palette
  function applyPalette(paletteKey) {
    const palette = palettes[paletteKey];
    const isDark = document.documentElement.dataset.theme !== 'light';
    const vars = isDark ? palette.dark : palette.light;

    // Apply CSS variables
    Object.entries(vars).forEach(([key, value]) => {
      document.documentElement.style.setProperty(key, value);
    });

    // Update background
    const landing = document.querySelector('.landing-page');
    if (landing) {
      const bg = isDark ? palette.bgDark : palette.bgLight;
      landing.style.backgroundImage = bg;
    }

    // Update buttons
    document.querySelectorAll('.btn-primary').forEach(btn => {
      btn.style.setProperty('--btn-bg', palette.btnColor);
      btn.style.background = palette.btnColor;
    });

    // Update feature cards gradient
    document.documentElement.style.setProperty('--card-gradient', palette.gradient);

    // Update toggle
    paletteName.textContent = palette.name;
    paletteDot.style.background = palette.dark['--sl-color-accent'];

    // Update active state
    options.forEach(opt => {
      opt.classList.toggle('active', opt.dataset.palette === paletteKey);
    });

    // Update logo color
    const logoCircle = document.querySelector('.logo-circle');
    if (logoCircle) {
      logoCircle.setAttribute('fill', palette.dark['--sl-color-accent']);
    }

    currentPalette = paletteKey;
    menu.classList.remove('open');
  }

  // Palette option click
  options.forEach(option => {
    option.addEventListener('click', () => {
      applyPalette(option.dataset.palette);
    });
  });

  // Listen for theme changes to reapply palette
  const observer = new MutationObserver(() => {
    applyPalette(currentPalette);
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>
