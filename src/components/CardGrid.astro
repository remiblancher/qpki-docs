---
/**
 * CardGrid - A responsive grid container for cards
 * Inspired by Biome website design
 */

interface Props {
  columns?: 2 | 3 | 4;
}

const { columns = 3 } = Astro.props;
---

<div class="card-grid" style={`--grid-cols: ${columns}`}>
  <slot />
</div>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: var(--q-space-6, 1.5rem);
    margin: var(--q-space-8, 2rem) 0;
  }

  @media (min-width: 50rem) {
    .card-grid {
      grid-template-columns: repeat(var(--grid-cols, 3), 1fr);
    }
  }
</style>
