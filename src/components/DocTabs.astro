---
const pathname = Astro.url.pathname;
const isQPKI = pathname.startsWith('/qpki/');
const isQLAB = pathname.startsWith('/qlab/');
const showTabs = isQPKI || isQLAB;
---

{showTabs && (
  <nav class="doc-tabs">
    <a href="/qpki/getting-started/quick-start/" class:list={["tab", { active: isQPKI }]}>
      QPKI
    </a>
    <a href="/qlab/overview/" class:list={["tab", { active: isQLAB }]}>
      QLAB
    </a>
  </nav>
)}

<style>
  .doc-tabs {
    position: fixed;
    top: var(--sl-nav-height);
    left: 0;
    right: 0;
    height: 2.5rem;
    background: var(--sl-color-bg-nav, #24272f);
    border-bottom: 1px solid var(--sl-color-hairline, #353841);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-left: 1rem;
    z-index: 9;
  }

  :global(:root[data-theme='light']) .doc-tabs {
    background: var(--sl-color-bg-nav, #f5f6f8);
    border-bottom-color: var(--sl-color-hairline, #c0c2c7);
  }

  .tab {
    padding: 0.5rem 1rem;
    border-radius: 4px;
    color: var(--sl-color-gray-3, #888b96);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.15s ease;
  }

  .tab:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-5, #353841);
  }

  .tab.active {
    color: #ffffff;
    background: var(--sl-color-accent);
  }

</style>
