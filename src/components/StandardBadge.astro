---
/**
 * StandardBadge - A badge/tag component for standards
 * Use for FIPS 203, RFC 5280, etc.
 */

interface Props {
  variant?: 'default' | 'accent' | 'success' | 'warning';
}

const { variant = 'accent' } = Astro.props;
---

<span class={`standard-badge standard-badge--${variant}`}>
  <slot />
</span>

<style>
  .standard-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--q-space-2, 0.5rem) var(--q-space-4, 1rem);
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--q-radius-full, 9999px);
    white-space: nowrap;
    transition: transform var(--q-transition-fast, 150ms ease);
  }

  .standard-badge:hover {
    transform: scale(1.02);
  }

  /* Default variant */
  .standard-badge--default {
    background: var(--q-gray-4, #27272a);
    color: var(--q-gray-7, #dadadc);
  }

  /* Accent variant (primary) */
  .standard-badge--accent {
    background: var(--sl-color-accent-low, #131e4f);
    border: 1px solid var(--sl-color-accent, #3447ff);
    color: var(--sl-color-accent-high, #60a5fa);
  }

  /* Success variant */
  .standard-badge--success {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid var(--q-color-success, #22c55e);
    color: #4ade80;
  }

  /* Warning variant */
  .standard-badge--warning {
    background: rgba(234, 179, 8, 0.1);
    border: 1px solid var(--q-color-warning, #eab308);
    color: #fbbf24;
  }

  /* Light mode adjustments */
  :root[data-theme='light'] .standard-badge--default {
    background: var(--q-gray-7, #dadadc);
    color: var(--q-gray-3, #202022);
  }

  :root[data-theme='light'] .standard-badge--accent {
    background: var(--sl-color-accent-low, #c2d9fa);
    color: var(--sl-color-accent-high, #093066);
  }

  :root[data-theme='light'] .standard-badge--success {
    background: rgba(34, 197, 94, 0.15);
    color: #15803d;
  }

  :root[data-theme='light'] .standard-badge--warning {
    background: rgba(234, 179, 8, 0.15);
    color: #a16207;
  }
</style>
