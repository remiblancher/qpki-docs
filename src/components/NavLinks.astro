---
// Custom NavLinks that forces page reload for project switching
---

{
  Astro.locals.starlightUtils.navLinks && (
    <ul class="nav-links-list">
      {Astro.locals.starlightUtils.navLinks.map((entry) => (
        <li>
          <button
            type="button"
            data-href={entry.href}
            aria-current={entry.isCurrent && "page"}
            class="nav-reload-link"
          >
            {entry.label}
          </button>
        </li>
      ))}
    </ul>
  )
}

<script is:inline>
(function() {
  var buttons = document.querySelectorAll('.nav-reload-link');
  for (var i = 0; i < buttons.length; i++) {
    buttons[i].addEventListener('click', function() {
      window.location.replace(this.getAttribute('data-href'));
    });
  }
})();
</script>

<style>
  .nav-links-list {
    display: flex;
    list-style: none;
    padding: 0;
    gap: var(--sl-nav-gap);
  }
  .nav-reload-link {
    background: none;
    border: none;
    font: inherit;
    text-decoration: none;
    color: var(--sl-color-gray-1);
    cursor: pointer;
    padding: 0;
  }

  .nav-reload-link:hover,
  .nav-reload-link:focus {
    color: var(--sl-color-white);
  }
</style>
