---
/**
 * Header - Biome-style navigation bar
 * Shared across all landing pages
 */
import ThemeToggle from './ThemeToggle.astro';
---

<header class="header">
  <nav class="header-nav">
    <a href="/" class="header-logo">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="32" height="32">
        <circle cx="20" cy="20" r="18" fill="#3447ff" />
        <text x="20" y="26" text-anchor="middle" fill="white" font-family="system-ui" font-weight="bold" font-size="16">Q</text>
      </svg>
      <span class="header-logo-text">QentriQ</span>
    </a>

    <div class="header-links">
      <a href="/qpki/getting-started/quick-start/" class="header-link">Docs</a>
      <a href="/qlab/overview/" class="header-link">Playground</a>
      <a href="/compare/" class="header-link">Compare</a>
      <a href="/about/" class="header-link">About</a>
      <a href="/blog/" class="header-link">Blog</a>
    </div>

    <div class="header-actions">
      <a href="https://github.com/remiblancher/post-quantum-pki" class="header-github" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>

      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(23, 24, 28, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  :root[data-theme='light'] .header {
    background: rgba(255, 255, 255, 0.95);
    border-bottom-color: rgba(0, 0, 0, 0.1);
  }

  .header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem 2rem;
    gap: 2rem;
  }

  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--q-gray-8, #f4f4f5);
    text-decoration: none;
  }

  :root[data-theme='light'] .header-logo {
    color: var(--q-gray-1, #020202);
  }

  .header-logo-text {
    display: none;
  }

  @media (min-width: 640px) {
    .header-logo-text {
      display: inline;
    }
  }

  .header-links {
    display: flex;
    gap: 1.5rem;
  }

  .header-link {
    color: var(--q-gray-6, #98989f);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 150ms ease;
  }

  .header-link:hover {
    color: var(--q-gray-8, #f4f4f5);
  }

  :root[data-theme='light'] .header-link {
    color: var(--q-gray-5, #64646c);
  }

  :root[data-theme='light'] .header-link:hover {
    color: var(--q-gray-1, #020202);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header-github {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--q-gray-6, #98989f);
    border-radius: 0.5rem;
    transition: all 150ms ease;
  }

  .header-github:hover {
    color: var(--q-gray-8, #f4f4f5);
    background: rgba(255, 255, 255, 0.1);
  }

  :root[data-theme='light'] .header-github {
    color: var(--q-gray-5, #64646c);
  }

  :root[data-theme='light'] .header-github:hover {
    color: var(--q-gray-1, #020202);
    background: rgba(0, 0, 0, 0.05);
  }

  @media (max-width: 639px) {
    .header-nav {
      padding: 0.75rem 1rem;
      gap: 1rem;
    }

    .header-links {
      gap: 1rem;
    }

    .header-link {
      font-size: 0.875rem;
    }
  }
</style>
