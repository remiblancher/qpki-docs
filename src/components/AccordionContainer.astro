---
/**
 * AccordionContainer - Container for grouping accordions
 */

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="accordion-container">
  {title && <h3 class="accordion-container-title">{title}</h3>}
  <div class="accordion-list">
    <slot />
  </div>
</div>

<style>
  .accordion-container {
    margin: 2rem 0;
  }

  .accordion-container-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    color: var(--sl-color-white, #f4f4f5);
  }

  .accordion-list {
    display: flex;
    flex-direction: column;
  }

  /* Light mode */
  :root[data-theme='light'] .accordion-container-title {
    color: var(--sl-color-black, #020202);
  }
</style>
