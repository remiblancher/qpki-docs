---
/**
 * Accordion - Animated accordion component
 * Inspired by DocKit Astro design
 */

interface Props {
  question: string;
  answer?: string;
  open?: boolean;
}

const { question, answer, open = false } = Astro.props;
---

<div class:list={["accordion", { active: open }]}>
  <button class="accordion-header" type="button" aria-expanded={open}>
    <span class="accordion-title">{question}</span>
    <div class="accordion-icon">
      <svg
        width="15"
        height="15"
        viewBox="0 0 15 15"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          class="vertical-line"
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M8.47821 6.52114V0H6.52169V6.52114H0V8.47766H6.52169V15H8.47821V8.47766H15V6.52114H8.47821Z"
          fill="currentColor"
        />
        <path
          class="horizontal-line"
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M0 6.52114V8.47766H15V6.52114H0Z"
          fill="currentColor"
        />
      </svg>
    </div>
  </button>
  <div class="accordion-body">
    {answer ? <p>{answer}</p> : <slot />}
  </div>
</div>

<script>
  function initAccordions() {
    const accordions = document.querySelectorAll('.accordion');

    accordions.forEach((accordion) => {
      const header = accordion.querySelector('.accordion-header');

      header?.addEventListener('click', () => {
        const isActive = accordion.classList.contains('active');
        accordion.classList.toggle('active');
        header.setAttribute('aria-expanded', String(!isActive));
      });
    });
  }

  // Run on initial load
  initAccordions();

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', initAccordions);
</script>

<style>
  .accordion {
    border: 1px solid var(--sl-color-gray-5, #383838);
    padding: 1.25rem 1.5rem;
    border-radius: 1rem;
    margin-bottom: 0.75rem;
    transition: border-color 0.3s ease;
  }

  .accordion:hover {
    border-color: var(--sl-color-accent, #E91E63);
  }

  .accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    text-align: left;
    color: inherit;
    font: inherit;
  }

  .accordion-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--sl-color-white, #f4f4f5);
  }

  .accordion-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--sl-color-gray-3, #8b8b8b);
    transition: color 0.3s ease;
  }

  .accordion:hover .accordion-icon {
    color: var(--sl-color-accent, #E91E63);
  }

  .accordion-icon svg {
    position: relative;
  }

  .accordion-icon .vertical-line {
    transition: transform 0.5s ease, opacity 0.5s ease;
    transform-origin: center;
  }

  .accordion-icon .horizontal-line {
    position: absolute;
    transition: transform 0.5s ease;
    transform-origin: center;
  }

  .accordion.active .accordion-icon .vertical-line {
    transform: rotate(90deg);
    opacity: 0;
  }

  .accordion.active .accordion-icon .horizontal-line {
    transform: rotate(180deg);
  }

  .accordion-body {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.5s ease,
      opacity 0.3s ease,
      margin-top 0.3s ease;
  }

  .accordion.active .accordion-body {
    max-height: 500px;
    opacity: 1;
    margin-top: 1rem;
  }

  .accordion-body :global(p) {
    color: var(--sl-color-gray-2, #c2c2c2);
    line-height: 1.7;
    margin: 0;
  }

  .accordion-body :global(p + p) {
    margin-top: 0.75rem;
  }

  /* Light mode */
  :root[data-theme='light'] .accordion {
    border-color: var(--sl-color-gray-5, #c2c2c2);
  }

  :root[data-theme='light'] .accordion:hover {
    border-color: var(--sl-color-accent, #C2185B);
  }

  :root[data-theme='light'] .accordion-title {
    color: var(--sl-color-black, #020202);
  }

  :root[data-theme='light'] .accordion-body :global(p) {
    color: var(--sl-color-gray-3, #585858);
  }
</style>
